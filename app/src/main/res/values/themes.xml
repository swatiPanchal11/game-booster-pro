<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.GameBooster" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_secondary</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
    </style>
    <!--  Buttons  -->
    <style name="Widget.GameBooster.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_primary</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="Widget.GameBooster.Button.Outlined" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/accent_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/accent_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="rippleColor">@color/accent_primary</item>
    </style>
    <!--  Text appearances — each must declare its own parent explicitly  -->
    <style name="TextAppearance.GameBooster.StatLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="TextAppearance.GameBooster.StatValue" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TextAppearance.GameBooster.SectionHeading" parent="TextAppearance.MaterialComponents.Overline">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>