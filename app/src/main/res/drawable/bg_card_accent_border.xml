<?xml version="1.0" encoding="utf-8"?>
<!-- bg_card_accent_border.xml - card with cyan top accent line -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#131824" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#1E2A40" />
        </shape>
    </item>
    <item android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#0D00E5FF"
                android:endColor="#00000000" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>